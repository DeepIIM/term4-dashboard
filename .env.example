# Copy this file to .env and fill in your values (for local testing only)
# For GitHub Actions, add these as Repository Secrets instead.

RESEND_API_KEY=re_your_api_key_here
EMAIL_TO=your-email@example.com

# Your personal course bundle as a single-line JSON string.
# REQUIRED for GitHub Actions so each fork uses its own timetable.
# Optional for local testing (falls back to courses.json if not set).
#
# How to get your bundle JSON:
#   1. Open the dashboard in your browser.
#   2. Pick your courses in the bundle picker and click Save Bundle.
#   3. Open DevTools → Console and run: copy(localStorage.getItem('term4_bundle'))
#   4. Paste the copied JSON as the value below (or into the COURSES_JSON GitHub Secret).
COURSES_JSON={"termStart":"2026-06-15","termEnd":"2026-08-08","cfaDate":"2026-08-19","courses":[]}
